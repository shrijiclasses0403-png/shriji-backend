# ── Database ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/shriji_classes

# ── JWT Secret (change this to any long random string) ────
SECRET_KEY=change_this_to_a_very_long_random_secret_key_123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Fast2SMS API Key ───────────────────────────────────────
# Get your FREE key at: https://www.fast2sms.com
# Sign up → Dashboard → Dev API → Copy API Key
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ── OTP Settings ──────────────────────────────────────────
OTP_EXPIRE_MINUTES=10

# ── Admin Credentials (first-time setup) ──────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@shriji123

# ── CORS (Frontend URL) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
